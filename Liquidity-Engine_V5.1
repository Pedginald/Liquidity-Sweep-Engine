        +"\t"+TrendToString(td.h4TrendAtEntry)+"\t"+VolToString(td.volRegimeAtEntry)
        +"\t"+DoubleToString(td.atrPercentileAtEntry,1)+"\t"+DoubleToString(td.adxAtEntry,2)
        +"\t"+DoubleToString(td.momentumBefore,3)+"\t"+(td.isLondonOrNY?"1":"0")
