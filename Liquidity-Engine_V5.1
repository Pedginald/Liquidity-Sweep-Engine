bool CheckMaxHoldTime()
  {
   int profileIdx = GetCurrentProfileIndex();
   if(profileIdx < 0)
      return false;

   if(gProfiles[profileIdx].maxHoldHours <= 0)
      return false;

   datetime now = TimeCurrent();
   int hoursInTrade = (int)((now - td.entry_time) / 3600);

   if(hoursInTrade >= gProfiles[profileIdx].maxHoldHours)
     {
      Print("⏰ MAX HOLD TIME [", gProfiles[profileIdx].name, "] | ", hoursInTrade, "h >= ", gProfiles[profileIdx].maxHoldHours, "h");
      return true;
     }
   return false;
  }

// ===================== BREAKEVEN MANAGEMENT =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CheckBreakeven()
  {
   if(td.positionID == 0)
     {
      return;
     }

   if(!PositionSelectByTicket(td.positionID))
     {
      state = IDLE;
      return;
     }

// Check if this is an existing protected trade we just picked up
   if(!td.breakevenActivated)
     {
      double currentSL = PositionGetDouble(POSITION_SL);
      bool isProtected = td.isSell ? (currentSL < td.fill) : (currentSL > td.fill);
      if(isProtected)
        {
         td.breakevenActivated = true;
         Print("📍 DETECTED: Trade already protected at BE+");
         return;
        }
     }

   if(td.breakevenActivated)
     {
      return;
     }

   int profileIdx = GetCurrentProfileIndex();
   if(profileIdx < 0)
     {
      return;
     }

   PairProfile profile = gProfiles[profileIdx];

   if(!profile.useBreakeven)
     {
      return;
     }

   double currentPrice = PositionGetDouble(POSITION_PRICE_CURRENT);
   double currentR = td.isSell ? (td.fill - currentPrice) / td.risk : (currentPrice - td.fill) / td.risk;

   if(currentR >= profile.beTriggerR)
     {
      double beOffset = td.risk * profile.beOffsetR;
      double newStop = td.isSell ? td.fill - beOffset : td.fill + beOffset;
      double currentStop = PositionGetDouble(POSITION_SL);

      bool shouldMove = td.isSell ? (newStop < currentStop || currentStop == 0)
                        : (newStop > currentStop || currentStop == 0);

      if(td.isSell && newStop >= td.stop)
         shouldMove = false;
      if(!td.isSell && newStop <= td.stop)
         shouldMove = false;

      if(shouldMove)
        {
         double currentTP = PositionGetDouble(POSITION_TP);

         if(trade.PositionModify(td.positionID, newStop, currentTP))
           {
            td.breakevenActivated = true;
            Print("🔒 BREAKEVEN ACTIVATED [", profile.name, "] | R:", DoubleToString(currentR, 1),
                  " | Stop moved to: ", DoubleToString(newStop, _Digits),
                  " | Locked: +", DoubleToString(profile.beOffsetR, 1), "R");
           }
         else
           {
            int error = GetLastError();
            Print("⚠️ BREAKEVEN FAILED [", profile.name, "] | Error:", error,
                  " | Desc:", GetErrorDescription(error));
           }
        }
     }
  }

// ===================== TRAILING STOP =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CheckTrailingStop()
  {
   if(td.positionID == 0)
      return;
   if(!PositionSelectByTicket(td.positionID))
     {
      state = IDLE;
      return;
     }
   if(td.remainingLots <= 0)
      return;  // Nothing left to trail

   int profileIdx = GetCurrentProfileIndex();
   if(profileIdx < 0)
      return;

   PairProfile profile = gProfiles[profileIdx];
   if(profile.trailingDistanceR <= 0)
      return;  // No trailing for this pair

// Only trail after we've hit the scale-out level (partial done or TP level reached)
   double currentPrice = PositionGetDouble(POSITION_PRICE_CURRENT);
   double currentR = td.isSell ? (td.fill - currentPrice) / td.risk : (currentPrice - td.fill) / td.risk;

// Check if we're past the TP level (where partial would have happened)
   if(currentR < td.targetR)
      return;  // Haven't reached TP yet, don't trail

// Calculate trailing stop level
   double trailDistance = td.risk * profile.trailingDistanceR;
   double newStop = td.isSell ? currentPrice + trailDistance : currentPrice - trailDistance;

   double currentStop = PositionGetDouble(POSITION_SL);

// Only move if it's improving our position (tighter/better stop)
   bool shouldMove = td.isSell ? (newStop < currentStop) : (newStop > currentStop);

// Don't trail below breakeven minimum
   double minStop = td.isSell ? td.fill - (td.risk * 0.1) : td.fill + (td.risk * 0.1);
   if(td.isSell && newStop > minStop)
      newStop = minStop;
   if(!td.isSell && newStop < minStop)
      newStop = minStop;

   if(shouldMove)
     {
      if(trade.PositionModify(td.positionID, newStop, PositionGetDouble(POSITION_TP)))
        {
         Print("📍 TRAILING [", profile.name, "] | R:", DoubleToString(currentR, 1),
               " | Trail ", DoubleToString(profile.trailingDistanceR, 1), "R | Stop→", DoubleToString(newStop, _Digits));
        }
     }
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CheckExistingTradeProtection()
  {
   if(td.positionID == 0)
      return;
   if(!PositionSelectByTicket(td.positionID))
      return;

// Check if stop is already better than entry (breakeven or better)
   double currentSL = PositionGetDouble(POSITION_SL);
   double entryPrice = td.fill;

   bool isProtected = false;

   if(td.isSell)
     {
      // For sells: SL below entry = profit locked
      if(currentSL < entryPrice)
         isProtected = true;
     }
   else
     {
      // For buys: SL above entry = profit locked
      if(currentSL > entryPrice)
         isProtected = true;
     }

   if(isProtected)
     {
      td.breakevenActivated = true;
      Print("📍 EXISTING TRADE DETECTED WITH PROTECTION [", _Symbol, "] | SL already at BE+");
     }
  }

// ===================== MILESTONE TRACKING =====================

double MilestoneR(int idx) { return (idx+1)*0.5; }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string MilestoneHeader(int idx)
  {
   double r=MilestoneR(idx);
   int whole=(int)MathFloor(r);
   if((r-whole)>0.01)
      return "TimeTo"+IntegerToString(whole)+"_5R";
   return "TimeTo"+IntegerToString(whole)+"R";
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string MilestoneTimeStr(datetime t)
  {
   if(t==MILESTONE_NOT_HIT)
      return "";
   return TimeToString(t,TIME_DATE|TIME_SECONDS);
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void UpdateTradeMetrics()
  {
   datetime currentBarTime = iTime(_Symbol, _Period, 0);
   bool isNewBar = (currentBarTime != td.lastBarTime);
   if(isNewBar)
     {
      td.lastBarTime = currentBarTime;
      td.barCount++;
     }
   if(td.barCount > MaxBarsInTrade)
      return;

   double s = CurrentSpreadPoints();
   td.spread_sum += s;
   td.spread_ticks++;
   td.spread_max = MathMax(td.spread_max, s);

   double hi = iHigh(_Symbol, _Period, 0);
   double lo = iLow(_Symbol, _Period, 0);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(ask > hi)
      hi = ask;
   if(bid < lo)
      lo = bid;

   if(td.isSell)
     {
      if(lo < td.best_price)
         td.best_price = lo;
      if(hi > td.worst_price)
         td.worst_price = hi;
     }
   else
     {
      if(hi > td.best_price)
         td.best_price = hi;
      if(lo < td.worst_price)
         td.worst_price = lo;
     }

   double favourableR, adverseR;

//// In UpdateTradeMetrics(), add:
//   if(td.timeToMaxR == MILESTONE_NOT_HIT)
//     {
//      double currentR = td.isSell ? (td.entry - iClose(_Symbol,_Period,0))/td.risk
//                        : (iClose(_Symbol,_Period,0) - td.entry)/td.risk;
//      td.maxR = MathMax(td.maxR, currentR);
//     }

   if(td.isSell)
     {
      favourableR = (td.entry - lo) / td.risk;
      adverseR = (hi - td.entry) / td.risk;
     }
   else
     {
      favourableR = (hi - td.entry) / td.risk;
      adverseR = (td.entry - lo) / td.risk;
     }

// Track maximum R reached for post-trade analysis
   if(favourableR > td.maxRReached)
      td.maxRReached = favourableR;

   if(ValidationMode && SpreadCostPips > 0)
     {
      double spreadCostR = (SpreadCostPips * (StringFind(_Symbol,"JPY")>=0 ? 0.01 : 0.0001)) / td.risk;
      favourableR = MathMax(favourableR - spreadCostR, 0);
     }

   datetime now = TimeCurrent();

   for(int i = 0; i < MILESTONE_COUNT; i++)
      if(td.timeToR[i] == MILESTONE_NOT_HIT && favourableR >= MilestoneR(i))
         td.timeToR[i] = now;

   if(td.timeToSL == MILESTONE_NOT_HIT && adverseR >= 1.0)
      td.timeToSL = now;

// Track when BE trigger level is first reached
   if(td.timeToBETrigger == MILESTONE_NOT_HIT && favourableR >= td.beTriggerR)
      td.timeToBETrigger = now;

// Track when price retraces to BE stop level AFTER trigger
   if(td.timeToBETrigger != MILESTONE_NOT_HIT && td.timeToBEStop == MILESTONE_NOT_HIT)
     {
      double beCurrentR = 0;
      if(td.isSell)
         beCurrentR = (td.entry - iClose(_Symbol, _Period, 0)) / td.risk;
      else
         beCurrentR = (iClose(_Symbol, _Period, 0) - td.entry) / td.risk;

      if(beCurrentR <= td.beOffsetR)
         td.timeToBEStop = now;
     }

   if(EnableTimeMilestones)
     {
      int minutesElapsed = (int)((now - td.entry_time) / 60);
      if(minutesElapsed >= 30 && td.timeTo30Min == MILESTONE_NOT_HIT)
        { td.timeTo30Min = now; td.priceAt30Min = td.isSell ? td.best_price : td.worst_price; }
      if(minutesElapsed >= 60 && td.timeTo1H == MILESTONE_NOT_HIT)
        { td.timeTo1H = now; td.priceAt1H = td.isSell ? td.best_price : td.worst_price; }
      if(minutesElapsed >= 240 && td.timeTo4H == MILESTONE_NOT_HIT)
        { td.timeTo4H = now; td.priceAt4H = td.isSell ? td.best_price : td.worst_price; }
      if(minutesElapsed >= 1440 && td.timeTo24H == MILESTONE_NOT_HIT)
        { td.timeTo24H = now; td.priceAt24H = td.isSell ? td.best_price : td.worst_price; }
     }
  }

// ===================== EXIT DETECTION =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
TradeOutcome GetCloseReason()
  {
   if(!HistorySelectByPosition(td.positionID))
      return OUTCOME_UNKNOWN;

   int total=HistoryDealsTotal();
   for(int i=total-1; i>=0; i--)
     {
      ulong dTicket=HistoryDealGetTicket(i);
      if((ulong)HistoryDealGetInteger(dTicket,DEAL_POSITION_ID) != td.positionID)
         continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dTicket,DEAL_ENTRY) != DEAL_ENTRY_OUT)
         continue;

      ENUM_DEAL_REASON reason=(ENUM_DEAL_REASON)HistoryDealGetInteger(dTicket,DEAL_REASON);
      if(reason==DEAL_REASON_SL)
         return OUTCOME_SL;
      if(reason==DEAL_REASON_TP)
         return OUTCOME_TP;
      if(reason==DEAL_REASON_EXPERT || reason==DEAL_REASON_CLIENT)
         return OUTCOME_TP;
     }
   return OUTCOME_UNKNOWN;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool PositionStillOpen()
  {
   if(td.positionID==0)
     {
      for(int i = PositionsTotal() - 1; i >= 0; i--)
        {
         ulong ticket = PositionGetTicket(i);
         if(PositionSelectByTicket(ticket))
           {
            if(PositionGetString(POSITION_SYMBOL) == _Symbol &&
               StringFind(PositionGetString(POSITION_COMMENT), td.isReversion ? "LiqRev" : "LiqCont") >= 0)
              {
               td.positionID = ticket;
               return true;
              }
           }
        }
      return false;
     }
   return PositionSelectByTicket(td.positionID);
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string GetMilestoneExitReason()
  {
   bool slHit=(td.timeToSL!=MILESTONE_NOT_HIT);
   int highestR=-1;
   for(int i=MILESTONE_COUNT-1; i>=0; i--)
      if(td.timeToR[i]!=MILESTONE_NOT_HIT)
        {
         highestR=i;
         break;
        }

   if(!slHit && highestR<0)
      return "EXPIRED";
   if(slHit && highestR<0)
      return "SL_HIT";
   if(!slHit && highestR>=0)
      return "EXPIRED";
   if(td.timeToSL <= td.timeToR[0])
      return "SL_HIT";
   return "EXPIRED";
  }

