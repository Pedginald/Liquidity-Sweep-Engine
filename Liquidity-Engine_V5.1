               session="London/NY";
            else
               if(dt.hour>=14&&dt.hour<17)
                  session="NY Open";
               else
                  if(dt.hour>=17&&dt.hour<22)
                     session="NY";

   string row=TimeToString(td.entry_time,TIME_DATE|TIME_SECONDS)
              +"\t"+IntegerToString(dt.hour)+"\t"+days[dt.day_of_week]
              +"\t"+(td.isSell?"SELL":"BUY")+"\t"+(td.isReversion?"REV":"CONT")
              +"\t"+DoubleToString(td.targetR,1)
              +"\t"+DoubleToString(td.entry,_Digits)+"\t"+DoubleToString(td.fill,_Digits)
              +"\t"+DoubleToString(td.stop,_Digits)+"\t"+DoubleToString(td.tp,_Digits)
              +"\t"+DoubleToString(td.spread_entry,1)+"\t"+DoubleToString(avgS,1)
              +"\t"+DoubleToString(td.spread_max,1)
              +"\t"+DoubleToString(td.best_price,_Digits)+"\t"+DoubleToString(td.worst_price,_Digits)
              +"\t"+DoubleToString(exitPrice,_Digits)+"\t"+exitReason
              +"\t"+IntegerToString(td.barCount);

              for(int i=0;i<MILESTONE_COUNT;i++)
                 row+="\t"+MilestoneTimeStr(td.timeToR[i]);

   row+="\t"+MilestoneTimeStr(td.timeToSL)+"\t"+MilestoneTimeStr(td.timeToFill)
        +"\t"+MilestoneTimeStr(td.timeTo30Min)+"\t"+MilestoneTimeStr(td.timeTo1H)
        +"\t"+MilestoneTimeStr(td.timeTo4H)+"\t"+MilestoneTimeStr(td.timeTo24H)
        +"\t"+DoubleToString(td.priceAt30Min,_Digits)+"\t"+DoubleToString(td.priceAt1H,_Digits)
        +"\t"+DoubleToString(td.priceAt4H,_Digits)+"\t"+DoubleToString(td.priceAt24H,_Digits);

   row+="\t"+DoubleToString(td.htfLevel,_Digits)+"\t"+IntegerToString(td.touchCount)
        +"\t"+IntegerToString(td.poolAge)+"\t"+IntegerToString(td.poolAgeFresh)
        +"\t"+DoubleToString(td.sweepSizePips,1)+"\t"+DoubleToString(td.sweepBodyPct,3)
        +"\t"+IntegerToString(td.barsToEntry)+"\t"+IntegerToString(td.barsToLevelRetouch)
        +"\t"+DoubleToString(td.entryDistPips,1)+"\t"+DoubleToString(td.stopSizePips,1)
