        +"\t"+MilestoneTimeStr(td.timeToBETrigger)
        +"\t"+MilestoneTimeStr(td.timeToBEStop)
        +"\t"+DoubleToString(td.maxRReached,3);

   FileWriteString(h,row+"\n");
   FileClose(h);

   int sIdx = GetSessionIndex();
   double tradePL = (exitReason == "TP_HIT") ? td.targetR : (exitReason == "SL_HIT") ? -1.0 : 0;
   if(td.scaleOutDone)
      tradePL = td.scaleOutR * 0.25;
   gSessionPL[sIdx] += tradePL;
   gSessionTrades[sIdx]++;

   Print("✅ ",prefix," | ",exitReason," | ",td.isSell?"SELL":"BUY",
         " | Bars:",td.barCount," | Slippage:",DoubleToString(td.slippagePips,2),"p");

   return true;
  }

// ===================== ORDER EXECUTION =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool SpreadAcceptable()
  {
   if(!UseSpreadFilter)
      return true;
   return (td.spread_entry*_Point) <= (td.risk*MaxSpreadPctOfRisk);
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool PlaceRealOrder()
  {
   double stopPoints=MathAbs(td.entry-td.stop)/_Point;
   double spread=CurrentSpreadPoints();
   long brokerMin=SymbolInfoInteger(_Symbol,SYMBOL_TRADE_STOPS_LEVEL);
   double reqMin=MathMax(spread,(double)brokerMin)+StopBufferPoints;

   if(stopPoints<reqMin)
     {
      Print("⛔ Stop too close: ", stopPoints, " pts < ", reqMin, " required");
      return false;
     }

   double lotSize=CalcLotSize(stopPoints, td.isSell, td.h4TrendAtEntry);
   double sl=NormalizeDouble(td.stop,_Digits);
   double tp=NormalizeDouble(td.tp,_Digits);
   string comment = (td.isReversion?"LiqRev":"LiqCont") + "_R" + DoubleToString(td.risk, 5);
// Result: "LiqRev_R0.50100" or "LiqCont_R0.50100"

   bool ok=td.isSell ? trade.Sell(lotSize,_Symbol,0,sl,tp,comment) : trade.Buy(lotSize,_Symbol,0,sl,tp,comment);

   if(!ok)
     {
      Print("❌ Order failed: ",GetLastError());
      return false;
     }

   ulong dealTicket=trade.ResultDeal();
   if(dealTicket>0 && HistoryDealSelect(dealTicket))
      td.positionID=(ulong)HistoryDealGetInteger(dealTicket,DEAL_POSITION_ID);
   else
      td.positionID=trade.ResultOrder();

   RecalcTPFromFill(trade.ResultPrice());

   Print("🚀 ENTRY | ", _Symbol, " | ", td.isSell?"SELL":"BUY",
         " | Lots: ", DoubleToString(lotSize,2),
         " | Fill: ", DoubleToString(td.fill, _Digits),
         " | Slippage: ", DoubleToString(td.slippagePips, 1), "p");

   return true;
  }

// ===================== INIT =====================

