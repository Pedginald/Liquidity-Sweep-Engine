        +"\t"+DoubleToString(SimulatedSlippagePips,1)
        +"\t"+DoubleToString(SpreadCostPips,1);

   row+="\t"+(td.scaleOutDone?"1":"0")+"\t"+DoubleToString(td.scaleOutR,2)
        +"\t"+DoubleToString(td.scaleOutPrice,_Digits)+"\t"+MilestoneTimeStr(td.scaleOutTime)
        +"\t"+DoubleToString(td.originalLots,2)+"\t"+DoubleToString(td.remainingLots,2);

