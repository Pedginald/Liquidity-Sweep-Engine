int OnInit()
  {
   if(FixedR_TP_Cont>MilestoneR(MILESTONE_COUNT-1) || FixedR_TP_Rev>MilestoneR(MILESTONE_COUNT-1))
     {
      Print("❌ ERROR: FixedR_TP exceeds milestone coverage");
      return INIT_FAILED;
     }

   InitProfiles();

   string mStr=Mode==REVERSION?"REVERSION":Mode==CONTINUATION?"CONTINUATION":"AUTO";

   gDailyStartEquity = AccountInfoDouble(ACCOUNT_EQUITY);

   Print("╔══════════════════════════════════════════════════╗");
   Print("║  Liquidity Engine v5.1 — FORWARD TEST EDITION  ║");
   Print("║  Plan: SACRED | Slippage: ",DoubleToString(SimulatedSlippagePips,1),"p | Spread: ",DoubleToString(SpreadCostPips,1),"p");
   Print("║  Mode: ",mStr," | ",ValidationMode?"VALIDATION":"LIVE");
   if(DemoDataCollectionMode)
     {
      Print("║  ⚠️ DEMO DATA COLLECTION MODE — ALL FILTERS OFF  ║");
      Print("║  (Wide spreads, correlation, daily limits DISABLED) ║");
     }
   else
     {
      Print("║  Safety: SpreadFilter=",RejectEntryOnWideSpread?"ON":"OFF"," | DailyLoss=",EnableDailyLossLimit?"ON":"OFF"," | CorrCheck=",UseCorrelationCheck?"ON":"OFF");
     }
   Print("╚══════════════════════════════════════════════════╝");

   UpdateMarketRegime();
   pending.active=false;
   ScanHTFLevels();
   lastHTFScan=iTime(_Symbol,PoolTF,0);
   lastH4Bar=iTime(_Symbol,PoolTF,0);

   if(AdoptExistingTrade())
     {
      Print("✅ VPS Restart Recovery: Resumed management of existing ", _Symbol, " trade");
     }
   else
     {
      state = IDLE;
      pending.active = false;
     }

   return INIT_SUCCEEDED;
  }

// ===================== MAIN TICK =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void OnTick()
  {
   if(!CheckDailyLossLimit())
     {
      if(state == IN_TRADE)
        {
         UpdateTradeMetrics();
         if(!ValidationMode && !td.scaleOutDone)
           {
            CheckScaleOut();
           }

         if(ValidationMode)
           {
            bool slHit = (td.timeToSL != MILESTONE_NOT_HIT);
            bool beTriggerHit = (td.timeToBETrigger != MILESTONE_NOT_HIT);
            bool beStopHit = (td.timeToBEStop != MILESTONE_NOT_HIT);
            double currentClose = iClose(_Symbol, _Period, 0);

            double exitPrice = 0;
            string exitReason = "";

            // Get TP hit time from milestones
            datetime tpTime = 0;
            for(int i = MILESTONE_COUNT - 1; i >= 0; i--)
               if(td.timeToR[i] != MILESTONE_NOT_HIT && MilestoneR(i) >= td.targetR - 0.01)
                 { tpTime = td.timeToR[i]; break; }

            // BE stop price
            double beStopPrice = td.isSell ? td.entry - (td.risk * td.beOffsetR)
                                 : td.entry + (td.risk * td.beOffsetR);

            datetime slTime = td.timeToSL;
            datetime beTime = (beTriggerHit && beStopHit) ? td.timeToBEStop : 0;

            // Find the EARLIEST terminal event
            // Candidates: TP, BE stop (if triggered), SL (if no BE trigger)

            // === Check TP ===
            if(tpTime > 0)
              {
               bool tpFirst = true;

               // BE stop hit before TP? → trade would have closed at BE
               if(beTime > 0 && beTime < tpTime)
                  tpFirst = false;

               // SL hit before TP and BE never triggered? → full SL loss
               if(slHit && !beTriggerHit && slTime <= tpTime)
                  tpFirst = false;

               if(tpFirst)
                 {
                  exitReason = "TP_HIT";
                  exitPrice = td.tp;
                  td.exitR = td.targetR;
                 }
              }

            // === BE stop hit (and it was before TP if TP exists) ===
            if(exitReason == "" && beTriggerHit && beStopHit)
              {
               // Check BE stop wasn't beaten by an earlier SL without BE
               // (can't happen — if BE triggered, BE is always before SL)
               exitReason = "BE_HIT";
               exitPrice = beStopPrice;
               td.exitR = td.beOffsetR;
              }

            // === SL hit, BE triggered but stop never retraced to BE level ===
            // This means price went: entry → 0.35R+ → then crashed past +0.1R
            // all the way to -1R without closing at BE stop level on any bar close.
            // In live trading the BE stop WOULD have caught it, so it's still BE_HIT.
            if(exitReason == "" && slHit && beTriggerHit)
              {
               exitReason = "BE_HIT";
               exitPrice = beStopPrice;
               td.exitR = td.beOffsetR;
              }

            // === Full SL, no BE ever triggered ===
            if(exitReason == "" && slHit && !beTriggerHit)
              {
               exitReason = "SL_HIT";
               exitPrice = td.stop;
               td.exitR = -1.0;
              }

            // === EXPIRED ===
            if(exitReason == "" && (td.barCount >= MaxBarsInTrade || CheckMaxHoldTime()))
              {
               exitReason = "EXPIRED";
               exitPrice = currentClose;
               if(td.isSell)
                  td.exitR = (td.entry - exitPrice) / td.risk;
               else
                  td.exitR = (exitPrice - td.entry) / td.risk;

               // If BE was active, floor at beOffsetR
               if(beTriggerHit)
                  td.exitR = MathMax(td.exitR, td.beOffsetR);
              }

            // Nothing triggered yet — stay in trade
            if(exitReason == "")
               return;

            td.exit_price = exitPrice;
            LogTrade(exitReason);
            state = IDLE;
            return;
           }
         else
           {
            if(!PositionStillOpen())
              {
               // Get actual exit price from deal history
               double liveExitPrice = 0;
               if(HistorySelectByPosition(td.positionID))
                 {
                  for(int i = HistoryDealsTotal() - 1; i >= 0; i--)
                    {
                     ulong dTicket = HistoryDealGetTicket(i);
                     if((ulong)HistoryDealGetInteger(dTicket, DEAL_POSITION_ID) == td.positionID
                        && (ENUM_DEAL_ENTRY)HistoryDealGetInteger(dTicket, DEAL_ENTRY) == DEAL_ENTRY_OUT)
                       {
                        liveExitPrice = HistoryDealGetDouble(dTicket, DEAL_PRICE);
                        break;
                       }
                    }
                 }

               // Calculate realized R
               if(liveExitPrice > 0)
                 {
                  if(td.isSell)
                     td.exitR = (td.fill - liveExitPrice) / td.risk;
                  else
                     td.exitR = (liveExitPrice - td.fill) / td.risk;
                 }

               TradeOutcome outcome = GetCloseReason();

               if(outcome == OUTCOME_SL)
                 {
                  if(td.breakevenActivated)
                    {
                     LogTrade("BE_HIT");
                    }
                  else
                    {
                     LogTrade("SL_HIT");
                    }
                 }
               else
                  if(outcome == OUTCOME_TP)
                    {
                     LogTrade("TP_HIT");
                    }
                  else
                    {
                     if(td.breakevenActivated && td.exitR < td.beOffsetR)
                        td.exitR = td.beOffsetR;
                     LogTrade(GetMilestoneExitReason());
                    }

               state = IDLE;
               return;
              }

            if(td.barCount >= MaxBarsInTrade || CheckMaxHoldTime())
              {
               double preClosePrice = PositionGetDouble(POSITION_PRICE_CURRENT);
               if(td.isSell)
                  td.exitR = (td.fill - preClosePrice) / td.risk;
               else
                  td.exitR = (preClosePrice - td.fill) / td.risk;

               if(td.breakevenActivated)
                  td.exitR = MathMax(td.exitR, td.beOffsetR);

               trade.PositionClose(td.positionID);
               LogTrade("EXPIRED");
               state = IDLE;
               return;
              }
            return;
           }
        }
      return;
     }

   if(state==IN_TRADE && td.risk<=0)
     {
      Print("⚠️ Resetting invalid trade state");
      state=IDLE;
      return;
     }

   if(state==IN_TRADE)
     {
      UpdateTradeMetrics();

      if(!ValidationMode && !td.scaleOutDone)
         CheckScaleOut();

      // ADD CHECKBREAKEVEN HERE - THIS IS THE RIGHT PLACE ↓↓↓
      if(!ValidationMode)
        {
         CheckBreakeven();
        }

      if(ValidationMode)
        {
         bool slHit = (td.timeToSL != MILESTONE_NOT_HIT);
         bool beTriggerHit = (td.timeToBETrigger != MILESTONE_NOT_HIT);
         bool beStopHit = (td.timeToBEStop != MILESTONE_NOT_HIT);
         double currentClose = iClose(_Symbol, _Period, 0);

         double exitPrice = 0;
         string exitReason = "";

         // Get TP hit time from milestones
         datetime tpTime = 0;
         for(int i = MILESTONE_COUNT - 1; i >= 0; i--)
            if(td.timeToR[i] != MILESTONE_NOT_HIT && MilestoneR(i) >= td.targetR - 0.01)
              { tpTime = td.timeToR[i]; break; }

         // BE stop price
         double beStopPrice = td.isSell ? td.entry - (td.risk * td.beOffsetR)
                              : td.entry + (td.risk * td.beOffsetR);

         datetime slTime = td.timeToSL;
         datetime beTime = (beTriggerHit && beStopHit) ? td.timeToBEStop : 0;

         // Find the EARLIEST terminal event
         // Candidates: TP, BE stop (if triggered), SL (if no BE trigger)

         // === Check TP ===
         if(tpTime > 0)
           {
            bool tpFirst = true;

            // BE stop hit before TP? → trade would have closed at BE
            if(beTime > 0 && beTime < tpTime)
               tpFirst = false;

            // SL hit before TP and BE never triggered? → full SL loss
            if(slHit && !beTriggerHit && slTime <= tpTime)
               tpFirst = false;

            if(tpFirst)
              {
               exitReason = "TP_HIT";
               exitPrice = td.tp;
               td.exitR = td.targetR;
              }
           }

         // === BE stop hit (and it was before TP if TP exists) ===
         if(exitReason == "" && beTriggerHit && beStopHit)
           {
            // Check BE stop wasn't beaten by an earlier SL without BE
            // (can't happen — if BE triggered, BE is always before SL)
            exitReason = "BE_HIT";
            exitPrice = beStopPrice;
            td.exitR = td.beOffsetR;
           }

         // === SL hit, BE triggered but stop never retraced to BE level ===
         // This means price went: entry → 0.35R+ → then crashed past +0.1R
         // all the way to -1R without closing at BE stop level on any bar close.
         // In live trading the BE stop WOULD have caught it, so it's still BE_HIT.
         if(exitReason == "" && slHit && beTriggerHit)
           {
            exitReason = "BE_HIT";
            exitPrice = beStopPrice;
            td.exitR = td.beOffsetR;
           }

         // === Full SL, no BE ever triggered ===
         if(exitReason == "" && slHit && !beTriggerHit)
           {
            exitReason = "SL_HIT";
            exitPrice = td.stop;
            td.exitR = -1.0;
           }

         // === EXPIRED ===
         if(exitReason == "" && (td.barCount >= MaxBarsInTrade || CheckMaxHoldTime()))
           {
            exitReason = "EXPIRED";
            exitPrice = currentClose;
            if(td.isSell)
               td.exitR = (td.entry - exitPrice) / td.risk;
            else
               td.exitR = (exitPrice - td.entry) / td.risk;

            // If BE was active, floor at beOffsetR
            if(beTriggerHit)
               td.exitR = MathMax(td.exitR, td.beOffsetR);
           }

         // Nothing triggered yet — stay in trade
         if(exitReason == "")
            return;

         td.exit_price = exitPrice;
         LogTrade(exitReason);
         state = IDLE;
         return;
        }
      else
        {
         if(!PositionStillOpen())
           {
            // Get actual exit price from deal history
            double liveExitPrice = 0;
            if(HistorySelectByPosition(td.positionID))
              {
               for(int i = HistoryDealsTotal() - 1; i >= 0; i--)
                 {
                  ulong dTicket = HistoryDealGetTicket(i);
                  if((ulong)HistoryDealGetInteger(dTicket, DEAL_POSITION_ID) == td.positionID
                     && (ENUM_DEAL_ENTRY)HistoryDealGetInteger(dTicket, DEAL_ENTRY) == DEAL_ENTRY_OUT)
                    {
                     liveExitPrice = HistoryDealGetDouble(dTicket, DEAL_PRICE);
                     break;
                    }
                 }
              }

            // Calculate realized R
            if(liveExitPrice > 0)
              {
               if(td.isSell)
                  td.exitR = (td.fill - liveExitPrice) / td.risk;
               else
                  td.exitR = (liveExitPrice - td.fill) / td.risk;
              }

            TradeOutcome outcome = GetCloseReason();

            if(outcome == OUTCOME_SL)
              {
               if(td.breakevenActivated)
                 {
                  LogTrade("BE_HIT");
                 }
               else
                 {
                  LogTrade("SL_HIT");
                 }
              }
            else
               if(outcome == OUTCOME_TP)
                 {
                  LogTrade("TP_HIT");
                 }
               else
                 {
                  if(td.breakevenActivated && td.exitR < td.beOffsetR)
                     td.exitR = td.beOffsetR;
                  LogTrade(GetMilestoneExitReason());
                 }

            state = IDLE;
            return;
           }

         if(td.barCount >= MaxBarsInTrade || CheckMaxHoldTime())
           {
            double preClosePrice = PositionGetDouble(POSITION_PRICE_CURRENT);
            if(td.isSell)
               td.exitR = (td.fill - preClosePrice) / td.risk;
            else
               td.exitR = (preClosePrice - td.fill) / td.risk;

            if(td.breakevenActivated)
               td.exitR = MathMax(td.exitR, td.beOffsetR);

            trade.PositionClose(td.positionID);
            LogTrade("EXPIRED");
            state = IDLE;
            return;
           }
         return;
        }
     }

   if(!CheckCorrelationRiskFunc())
      return;

   datetime currentChartBar=iTime(_Symbol,_Period,0);
   bool newChartBar=(currentChartBar!=lastChartBar);
   if(newChartBar)
      lastChartBar=currentChartBar;

   datetime currentH4=iTime(_Symbol,PoolTF,0);
   bool newH4Bar=(currentH4!=lastH4Bar);

   if(newH4Bar)
     {
      lastH4Bar=currentH4;
      if(currentH4!=lastHTFScan)
        {
         ScanHTFLevels();
         lastHTFScan=currentH4;
        }
      if(!pending.active && state==IDLE)
         CheckH4Confirmation();

      if(pending.active)
        {
         pending.h4BarsWaited++;
         if(pending.h4BarsWaited>MaxH4BarsToWait)
           { pending.active=false; Print("⏱️ H4 wait expired"); }
        }
     }

   if(!newChartBar)
      return;
   if(!pending.active)
      return;
   if(state!=IDLE)
      return;

   pending.entryBarsWaited++;
   if(pending.entryBarsWaited>MaxEntryBarsToWait)
     { pending.active=false; Print("⏱️ Entry wait expired"); return; }

   if(!CheckEntry())
      return;

   PrepareTrade();

   if(!pending.active)
      return;  // StopATR gate rejected, bail out

   if(!SpreadAcceptableForEntry())
     {
      pending.active = false;
      return;
     }

   if(td.risk<=0)
     {
      pending.active=false;
      return;
     }
   if(!SpreadAcceptable())
     {
      pending.active=false;
      return;
     }

   Print(">>> ENTRY SIGNAL | ",td.isReversion?"REV":"CONT"," | ",td.isSell?"SELL":"BUY",
         " @ ",DoubleToString(td.entry,_Digits),
         " | Risk: ",DoubleToString(td.stopSizePips,1),"p",
         " | Target: ",DoubleToString(td.targetR,1),"R");

   pending.active=false;

   if(!ValidationMode)
     {
      if(!PlaceRealOrder())
         return;
     }
   else
     {
      td.fill_time=td.entry_time;
      td.timeToFill=td.entry_time;
     }

   state=IN_TRADE;
  }
