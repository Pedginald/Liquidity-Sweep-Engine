int GetSessionIndex()
  {
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   if(dt.hour >= 22 || dt.hour < 7)
      return 0;
   if(dt.hour >= 8 && dt.hour < 9)
      return 2;
   if(dt.hour >= 9 && dt.hour < 12)
      return 1;
   if(dt.hour >= 12 && dt.hour < 14)
      return 3;
   if(dt.hour >= 14 && dt.hour < 17)
      return 5;
   if(dt.hour >= 17 && dt.hour < 22)
      return 4;
   return 0;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
string GetSessionNameFromIdx(int idx)
  {
   string names[] = {"Asia","London","LondonOpen","London/NY","NY","NYOpen"};
   if(idx >= 0 && idx < 6)
      return names[idx];
   return "Unknown";
  }

// Safety checks - bypassed in DemoDataCollectionMode
bool CheckDailyLossLimit()
  {
   if(DemoDataCollectionMode)
      return true;
   if(!EnableDailyLossLimit)
      return true;

   double currentEquity = AccountInfoDouble(ACCOUNT_EQUITY);
   double dailyPL = (currentEquity - gDailyStartEquity) / gDailyStartEquity * 100.0;

   if(dailyPL <= -MaxDailyLossPercent)
     {
      Print("🛑 DAILY LOSS LIMIT HIT | P&L: ", DoubleToString(dailyPL, 2), "% | Trading halted");
      return false;
     }
   return true;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CheckCorrelationRiskFunc()
  {
   if(DemoDataCollectionMode)
      return true;
   if(!UseCorrelationCheck)
      return true;

   int openCount = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
     {
      ulong ticket = PositionGetTicket(i);
      if(PositionSelectByTicket(ticket))
        {
         if(PositionGetString(POSITION_SYMBOL) == _Symbol)
            return false;
         openCount++;
        }
     }

// Static variable to track last logged count
   static int lastLoggedCount = -1;

   if(openCount >= MaxSimultaneousTrades)
     {
      // Only log if this is a NEW rejection (count changed)
      if(openCount != lastLoggedCount)
        {
         Print("⛔ CORRELATION_LIMIT | Trade rejected | Open: ", openCount, " >= Max: ", MaxSimultaneousTrades);
         lastLoggedCount = openCount;
        }
      return false;
     }

// Reset when below limit
   lastLoggedCount = -1;
   return true;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void LogExecutionQuality()
  {
   double assumedEntry = UseOpenForValidation ? iOpen(_Symbol, _Period, 0) : iClose(_Symbol, _Period, 1);
   double actualSlippage = ToPips(MathAbs(td.fill - assumedEntry));
   double deviationFromSim = actualSlippage - SimulatedSlippagePips;

   totalSlippageDeviation += deviationFromSim;
   slippageSampleCount++;

   if(VerboseLogging)
     {
      Print("📊 EXEC_QUALITY | ", _Symbol, " | Assumed: ", DoubleToString(assumedEntry, _Digits),
            " | Fill: ", DoubleToString(td.fill, _Digits),
            " | ActualSlip: ", DoubleToString(actualSlippage, 2), "p",
            " | Simulated: ", DoubleToString(SimulatedSlippagePips, 1), "p",
            " | Deviation: ", DoubleToString(deviationFromSim, 2), "p",
            " | CumulativeAvgDev: ", DoubleToString(totalSlippageDeviation/slippageSampleCount, 2), "p",
            " | Session: ", GetSessionNameFromIdx(GetSessionIndex()));
     }
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool SpreadAcceptableForEntry()
  {
   if(DemoDataCollectionMode)
      return true;
   if(!RejectEntryOnWideSpread)
      return true;

// Get current spread in pips
   double spreadPips = ToPips(CurrentSpreadPoints() * _Point);

// Get pair-specific limit (or use global default)
   int profileIdx = GetCurrentProfileIndex();
   double absoluteMax = (profileIdx >= 0) ? gProfiles[profileIdx].maxSpreadPips : MaxSpreadPips;

// Calculate relative limit (% of risk)
   double relativeMax = 999999; // Default huge if risk not set
   if(td.risk > 0)
     {
      relativeMax = ToPips(td.risk * MaxSpreadPctOfRisk);
     }

// Use the tighter of the two limits
   double effectiveMax = MathMin(absoluteMax, relativeMax);

   if(spreadPips > effectiveMax)
     {
      string limitType = (absoluteMax < relativeMax) ? "Absolute" : "Relative(%Risk)";
      Print("⛔ SPREAD_REJECT | ", _Symbol, " | Spread: ", DoubleToString(spreadPips, 1),
            "p | Limit: ", DoubleToString(effectiveMax, 1), "p (", limitType, ")",
            " | ProfileMax: ", DoubleToString(absoluteMax, 1),
            " | RiskPctMax: ", DoubleToString(relativeMax, 1));
      return false;
     }
   return true;
  }

