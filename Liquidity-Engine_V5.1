     {
      Print("❌ Log failed: ",GetLastError());
      return false;
     }

   if(!exists)
     {
      string header="Date\tHour\tDayOfWeek\tDir\tMode\tTargetR"
                    "\tEntry\tFill\tStop\tTP\tSpreadEntry\tSpreadAvg\tSpreadMax"
                    "\tBestPrice\tWorstPrice\tExitPrice\tExitReason\tBarCount";
