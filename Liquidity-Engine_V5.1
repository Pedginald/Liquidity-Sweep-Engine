int GetCurrentProfileIndex()
  {
   for(int i=0; i<gProfileCount; i++)
      if(StringFind(_Symbol, gProfiles[i].name) >= 0)
         return i;
   return -1;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool ProfileAllowsEntry()
  {
   if(!UsePairProfiles)
      return true;
   int idx = GetCurrentProfileIndex();
   if(idx < 0)
      return true;
   if(gProfiles[idx].requireStrongTrend && pending.regime.adxValue < 25.0)
     {
      Print("⛔ ", _Symbol, " rejected: ADX ", DoubleToString(pending.regime.adxValue,1), " < 25.0");
      return false;
     }
   return true;
  }

// ===================== MARKET DATA =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CurrentSpreadPoints()
  {
   return (SymbolInfoDouble(_Symbol,SYMBOL_ASK)-SymbolInfoDouble(_Symbol,SYMBOL_BID))/_Point;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double GetATR(int period, ENUM_TIMEFRAMES tf)
  {
   int h=iATR(_Symbol,tf,period);
   double a[];
   double result = 0;
   if(CopyBuffer(h,0,0,1,a)>0)
      result = a[0];
   IndicatorRelease(h);
   return result;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
TrendRegime GetH4Trend()
  {
   int maHandle = iMA(_Symbol, PoolTF, H4TrendMAPeriod, 0, MODE_SMA, PRICE_CLOSE);
   double maVal[];
   if(CopyBuffer(maHandle, 0, 0, 1, maVal) <= 0)
     {
      IndicatorRelease(maHandle);
      return TREND_NEUTRAL;
     }
   IndicatorRelease(maHandle);

   double close = iClose(_Symbol, PoolTF, 0);
   double threshold = GetATR(14, PoolTF) * 0.1;

   if(close > maVal[0] + threshold)
      return TREND_BULLISH;
   if(close < maVal[0] - threshold)
      return TREND_BEARISH;
   return TREND_NEUTRAL;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void UpdateMarketRegime()
  {
   double atrCurrent = GetATR(14, PoolTF);
   double atrLookback[100];
   int atrHandle = iATR(_Symbol, PoolTF, 14);
   CopyBuffer(atrHandle, 0, 1, 100, atrLookback);
   IndicatorRelease(atrHandle);

   int rank = 0;
   for(int i=0; i<100; i++)
      if(atrCurrent > atrLookback[i])
         rank++;
   currentRegime.atrPercentile = rank;

   if(rank < 20)
      currentRegime.volatility = VOL_LOW;
   else
      if(rank < 50)
         currentRegime.volatility = VOL_NORMAL;
      else
         if(rank < 80)
            currentRegime.volatility = VOL_HIGH;
         else
            currentRegime.volatility = VOL_EXTREME;

   int adxHandle = iADX(_Symbol, PoolTF, 14);
   double adxVal[];
   CopyBuffer(adxHandle, 0, 0, 1, adxVal);
   currentRegime.adxValue = adxVal[0];
   IndicatorRelease(adxHandle);

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   currentRegime.isLondonOrNY = (dt.hour >= 8 && dt.hour < 17) || (dt.hour >= 13 && dt.hour < 22);
   currentRegime.trend = GetH4Trend();
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double ToPips(double priceDistance)
  {
// Gold and silver use 2 decimal places (0.01 = 1 pip)
   if(StringFind(_Symbol,"XAU")>=0 || StringFind(_Symbol,"XAG")>=0)
      return priceDistance / 0.01;

// JPY pairs use 2 decimal places (0.01 = 1 pip)
   if(StringFind(_Symbol,"JPY")>=0)
      return priceDistance / 0.01;

// Standard forex uses 4 decimal places (0.0001 = 1 pip)
   return priceDistance / 0.0001;
  }

// ===================== SIZING =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double GetSessionMultiplier()
  {
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   if(dt.hour >= 8 && dt.hour < 9)
      return LondonOpenSizeMult;
   if(dt.hour >= 12 && dt.hour < 14)
      return LondonNYSizeMult;
   if(dt.hour >= 22 || dt.hour < 7)
      return AsiaSizeMult;
   return 1.0;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double GetTrendMultiplier(bool isSell, TrendRegime trend)
  {
   if(trend == TREND_BEARISH && isSell)
      return BearTrendSizeMult;
   if(trend == TREND_BULLISH && !isSell)
      return BullTrendSizeMult;
   return 1.0;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
double CalcLotSize(double stopDistance, bool isSell, TrendRegime trend)
  {
   if(stopDistance<=0)
      return SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN);

   double balance=AccountInfoDouble(ACCOUNT_BALANCE);
   double baseRiskAmount=balance*RiskPercent/100.0;

   double sessionMult = GetSessionMultiplier();
   double trendMult = GetTrendMultiplier(isSell, trend);
   double profileMult = 1.0;

   int profileIdx = GetCurrentProfileIndex();
   if(profileIdx >= 0 && UsePairProfiles)
      profileMult = gProfiles[profileIdx].positionWeight / 0.10;

   double adjustedRisk = baseRiskAmount * sessionMult * trendMult * profileMult;

   double tickValue=SymbolInfoDouble(_Symbol,SYMBOL_TRADE_TICK_VALUE);
   double tickSize=SymbolInfoDouble(_Symbol,SYMBOL_TRADE_TICK_SIZE);
   double pointValue=tickValue*(_Point/tickSize);
   double lots=adjustedRisk/(stopDistance*pointValue);

   double minLot=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN);
   double maxLot=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MAX);
   double lotStep=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_STEP);

   lots=MathFloor(lots/lotStep)*lotStep;
   lots=MathMin(MathMax(lots,minLot),maxLot);

   return lots;
  }

// ===================== HTF POOL DETECTION =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void ScanHTFLevels()
  {
   gLevelCount=0;
   double atr=GetATR(14,PoolTF);
   if(atr<=0)
     {
      Print("⚠️ HTF ATR unavailable");
      return;
     }

   double tol=atr*TouchTolerance;
   double levelPrices[100];
   int levelTouches[100];
   int levelFirstBar[100];
   int levelLastBar[100];
   bool levelIsSupport[100];
   int count=0;
   int barsAvail=MathMin(HTFLookback,iBars(_Symbol,PoolTF)-1);

   for(int i=1;i<=barsAvail;i++)
     {
      double hi=iHigh(_Symbol,PoolTF,i);
      double lo=iLow(_Symbol,PoolTF,i);
      bool matched=false;

      for(int j=0;j<count;j++)
        {
         if(levelIsSupport[j] && MathAbs(lo-levelPrices[j])<=tol)
           {
            levelTouches[j]++;
            levelPrices[j]=(levelPrices[j]*(levelTouches[j]-1)+lo)/levelTouches[j];
            levelFirstBar[j]=MathMax(levelFirstBar[j],i);
            levelLastBar[j]=MathMin(levelLastBar[j],i);
            matched=true;
            break;
           }
        }
      if(!matched && count<100)
        {
         levelPrices[count]=lo;
         levelTouches[count]=1;
         levelFirstBar[count]=i;
         levelLastBar[count]=i;
         levelIsSupport[count]=true;
         count++;
        }

      matched=false;
      for(int j=0;j<count;j++)
        {
         if(!levelIsSupport[j] && MathAbs(hi-levelPrices[j])<=tol)
           {
            levelTouches[j]++;
            levelPrices[j]=(levelPrices[j]*(levelTouches[j]-1)+hi)/levelTouches[j];
            levelFirstBar[j]=MathMax(levelFirstBar[j],i);
            levelLastBar[j]=MathMin(levelLastBar[j],i);
            matched=true;
            break;
           }
        }
      if(!matched && count<100)
        {
         levelPrices[count]=hi;
         levelTouches[count]=1;
         levelFirstBar[count]=i;
         levelLastBar[count]=i;
         levelIsSupport[count]=false;
         count++;
        }
     }

   double currentPrice=iClose(_Symbol,_Period,0);
   int sc=0,rc=0;
   for(int i=0;i<count && gLevelCount<6;i++)
     {
      if(levelTouches[i]<MinTouches)
         continue;
      if(levelFirstBar[i]<MinPoolAge)
         continue;
      if(levelFirstBar[i]>MaxPoolAge)
         continue;

      bool swept=false;
      for(int b=1;b<=FreshnessLookback;b++)
        {
         double closeB=iClose(_Symbol,PoolTF,b);
         if(levelIsSupport[i] && closeB<levelPrices[i]-tol)
           {
            swept=true;
            break;
           }
         if(!levelIsSupport[i] && closeB>levelPrices[i]+tol)
           {
            swept=true;
            break;
           }
        }
      if(swept)
         continue;

      if(levelIsSupport[i] && levelPrices[i]>=currentPrice)
         continue;
      if(!levelIsSupport[i] && levelPrices[i]<=currentPrice)
         continue;
      if(levelIsSupport[i] && sc>=3)
         continue;
      if(!levelIsSupport[i] && rc>=3)
         continue;

      if(levelIsSupport[i])
         sc++;
      else
         rc++;

      gLevels[gLevelCount].price=levelPrices[i];
      gLevels[gLevelCount].touches=levelTouches[i];
      gLevels[gLevelCount].firstBarAgo=levelFirstBar[i];
      gLevels[gLevelCount].lastBarAgo=levelLastBar[i];
      gLevels[gLevelCount].isSupport=levelIsSupport[i];
      gLevels[gLevelCount].active=true;
      gLevelCount++;
     }
   Print("🔍 HTF scan: ",gLevelCount," levels | Vol: ",VolToString(currentRegime.volatility),
         " | Trend: ",TrendToString(currentRegime.trend));
  }

// ===================== H4 CONFIRMATION =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CheckH4Confirmation()
  {
   if(gLevelCount==0)
      return false;

   UpdateMarketRegime();

   double atr=GetATR(14,PoolTF);
   double proximity=atr*ProximityATRMult;
   TrendRegime trend=currentRegime.trend;

   double h4_o1=iOpen(_Symbol,PoolTF,1);
   double h4_c1=iClose(_Symbol,PoolTF,1);
   double h4_h1=iHigh(_Symbol,PoolTF,1);
   double h4_l1=iLow(_Symbol,PoolTF,1);

   SweepContext ctx;
   double close6BarsAgo=iClose(_Symbol,PoolTF,6);
   ctx.momentumBefore=MathAbs(h4_c1-close6BarsAgo)/atr;
   ctx.priorDayRange=iHigh(_Symbol,PoolTF,1)-iLow(_Symbol,PoolTF,1);
   ctx.barsSinceLastTouch=0;

   for(int i=0;i<gLevelCount;i++)
     {
      if(!gLevels[i].active)
         continue;

      double lp=gLevels[i].price;
      double dist=gLevels[i].isSupport?MathAbs(h4_l1-lp):MathAbs(h4_h1-lp);
      if(dist>proximity)
         continue;

      if(gLevels[i].isSupport)
        {
         if(h4_l1>=lp)
            continue;
         bool rejectedBack=(h4_c1>lp&&h4_c1>h4_o1);
         bool brokeThrough=(h4_c1<lp&&h4_c1<h4_o1);

         if(rejectedBack && (Mode==REVERSION||Mode==AUTO))
           {
            InitPending(false,true,i,h4_o1,h4_c1,h4_h1,h4_l1,atr,trend,ctx);
            Print("🎯 H4 REV BUY @ ",DoubleToString(lp,_Digits));
            return true;
           }
         if(brokeThrough && (Mode==CONTINUATION||Mode==AUTO))
           {
            InitPending(true,false,i,h4_o1,h4_c1,h4_h1,h4_l1,atr,trend,ctx);
            Print("🎯 H4 CONT SELL @ ",DoubleToString(lp,_Digits));
            return true;
           }
        }
      else
        {
         if(h4_h1<=lp)
            continue;
         bool rejectedBack=(h4_c1<lp&&h4_c1<h4_o1);
         bool brokeThrough=(h4_c1>lp&&h4_c1>h4_o1);

         if(rejectedBack && (Mode==REVERSION||Mode==AUTO))
           {
            InitPending(true,true,i,h4_o1,h4_c1,h4_h1,h4_l1,atr,trend,ctx);
            Print("🎯 H4 REV SELL @ ",DoubleToString(lp,_Digits));
            return true;
           }
         if(brokeThrough && (Mode==CONTINUATION||Mode==AUTO))
           {
            InitPending(false,false,i,h4_o1,h4_c1,h4_h1,h4_l1,atr,trend,ctx);
            Print("🎯 H4 CONT BUY @ ",DoubleToString(lp,_Digits));
            return true;
           }
        }
     }
   return false;
  }

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void InitPending(bool sell, bool isRev, int idx, double o1, double c1,
                 double h1, double l1, double atr, TrendRegime trend, const SweepContext &ctx)
  {
   pending.active=true;
   pending.isSell=sell;
   pending.isReversion=isRev;
   pending.htfLevel=gLevels[idx].price;
   pending.h4SweepHigh=h1;
   pending.h4SweepLow=l1;
   pending.h4SweepOpen=o1;
   pending.h4SweepClose=c1;
   pending.h4ConfirmTime=iTime(_Symbol,PoolTF,1);
   pending.h4BarsWaited=0;
   pending.entryBarsWaited=0;
   pending.touchCount=gLevels[idx].touches;
   pending.poolAge=gLevels[idx].firstBarAgo;
   pending.poolAgeFresh=gLevels[idx].lastBarAgo;
   pending.atrH4AtConfirm=atr;
   pending.barsToLevelRetouch=-1;
   pending.h4Trend=trend;
   pending.context=ctx;
   pending.regime=currentRegime;
  }

// ===================== ENTRY TIMING =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool CheckEntry()
  {
   if(!pending.active)
      return false;
   if(UsePairProfiles && !ProfileAllowsEntry())
     {
      pending.active=false;
      Print("⛔ Entry blocked by profile filter for ", _Symbol);
      return false;
     }

   double o1=iOpen(_Symbol,_Period,1);
   double c1=iClose(_Symbol,_Period,1);
   double lp=pending.htfLevel;
   double atr=GetATR(14,_Period);

   double proximity=pending.atrH4AtConfirm*0.25;
   if(pending.barsToLevelRetouch<0 && MathAbs(c1-lp)<=proximity)
      pending.barsToLevelRetouch=pending.entryBarsWaited;

   if(pending.isReversion)
     {
      if(!pending.isSell)
        {
         if(c1>lp && c1>o1 && (c1-o1)>atr*0.3)
            return true;
        }
      else
        {
         if(c1<lp && c1<o1 && (o1-c1)>atr*0.3)
            return true;
        }
     }
   else
     {
      if(pending.isSell)
        {
         if(iHigh(_Symbol,_Period,1)>=(lp-atr*PullbackATRMult) && c1<o1 && c1<lp)
            return true;
        }
      else
        {
         if(iLow(_Symbol,_Period,1)<=(lp+atr*PullbackATRMult) && c1>o1 && c1>lp)
            return true;
        }
     }
   return false;
  }

// ===================== TRADE PREPARATION =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void PrepareTrade()
  {
   double targetR;
   int profileIdx = -1;

   if(UsePairProfiles)
     {
      profileIdx = GetCurrentProfileIndex();
      if(profileIdx >= 0)
        {
         targetR = gProfiles[profileIdx].optimalTP;
         if(!gProfiles[profileIdx].quickExit && pending.regime.volatility == VOL_EXTREME)
           {
            targetR *= 1.15;
            targetR = MathMin(targetR, gProfiles[profileIdx].maxTP);
            Print("⚡ VOL_EXTREME boost for ", gProfiles[profileIdx].name, ": TP ", DoubleToString(targetR,1), "R");
           }
        }
      else
         targetR = pending.isReversion ? FixedR_TP_Rev : FixedR_TP_Cont;
     }
   else
      targetR = pending.isReversion ? FixedR_TP_Rev : FixedR_TP_Cont;

   if(targetR > MilestoneR(MILESTONE_COUNT-1))
     {
      Print("⚠️ Target TP ", targetR, "R exceeds milestone limit, clamping to ", MilestoneR(MILESTONE_COUNT-1), "R");
      targetR = MilestoneR(MILESTONE_COUNT-1);
     }

   double atrM5 = GetATR(14, _Period);

   td.isSell = pending.isSell;
   td.isReversion = pending.isReversion;
   td.targetR = targetR;
   td.htfLevel = pending.htfLevel;
   td.exit_price = 0;

   td.entry = UseOpenForValidation && ValidationMode ? iOpen(_Symbol, _Period, 0) : iClose(_Symbol, _Period, 1);

   double sweepBuffer = UseATRBuffer ? pending.atrH4AtConfirm * SweepBufferATRMult : SweepBufferPips * _Point;
   td.stop = td.isSell ? pending.h4SweepHigh + sweepBuffer : pending.h4SweepLow - sweepBuffer;

   td.risk = MathAbs(td.entry - td.stop);
   td.tp = td.isSell ? td.entry - td.risk * targetR : td.entry + td.risk * targetR;

   td.spread_entry = CurrentSpreadPoints();
   td.spread_max = td.spread_entry;
   td.spread_sum = td.spread_entry;
   td.spread_ticks = 1;
   td.best_price = td.entry;
   td.worst_price = td.entry;
   td.entry_time = TimeCurrent();
   td.fill_time = 0;
   td.positionID = 0;
   td.barCount = 0;
   td.lastBarTime = iTime(_Symbol, _Period, 0);

   for(int i = 0; i < MILESTONE_COUNT; i++)
      td.timeToR[i] = MILESTONE_NOT_HIT;
   td.timeToSL = MILESTONE_NOT_HIT;
   td.timeTo30Min = MILESTONE_NOT_HIT;
   td.timeTo1H = MILESTONE_NOT_HIT;
   td.timeTo4H = MILESTONE_NOT_HIT;
   td.timeTo24H = MILESTONE_NOT_HIT;

   td.touchCount = pending.touchCount;
   td.poolAge = pending.poolAge;
   td.poolAgeFresh = pending.poolAgeFresh;
   td.barsToEntry = pending.entryBarsWaited;
   td.barsToLevelRetouch = pending.barsToLevelRetouch;
   td.atrH4 = pending.atrH4AtConfirm;
   td.atrM5 = atrM5;
   td.h4TrendAtEntry = pending.h4Trend;
   td.volRegimeAtEntry = pending.regime.volatility;
   td.atrPercentileAtEntry = pending.regime.atrPercentile;
   td.adxAtEntry = pending.regime.adxValue;
   td.momentumBefore = pending.context.momentumBefore;
   td.isLondonOrNY = pending.regime.isLondonOrNY;
   td.slippagePips = 0;
   td.fillLatencyMs = 0;

   td.stopSizePips = ToPips(td.risk);
   td.entryDistPips = ToPips(MathAbs(td.entry - td.htfLevel));

// =====================================================================
// STOPATR GATE — Quality filter for stop size relative to volatility
// =====================================================================
   if(profileIdx >= 0 && gProfiles[profileIdx].maxStopATR > 0)
     {
      double atrPips = ToPips(td.atrH4);

      if(atrPips <= 0)  // Safety check
        {
         if(VerboseLogging)
            Print("⚠️ STOP_ATR_SKIP | ", _Symbol, " | ATR invalid: ", atrPips);
         pending.active = false;
         return;
        }

      double stopATR = td.stopSizePips / atrPips;

      if(stopATR >= gProfiles[profileIdx].maxStopATR)
        {
         if(VerboseLogging)
            Print("⛔ STOP_ATR_REJECT | ", _Symbol,
                  " | StopATR: ", DoubleToString(stopATR, 2),
                  " >= ", DoubleToString(gProfiles[profileIdx].maxStopATR, 1),
                  " | Stop: ", DoubleToString(td.stopSizePips, 1), "p",
                  " | ATR: ", DoubleToString(atrPips, 1), "p");
         pending.active = false;
         return;
        }
     }
// =====================================================================

   if(pending.isReversion)
      td.sweepSizePips = td.isSell ? ToPips(MathAbs(pending.h4SweepHigh - pending.htfLevel))
                         : ToPips(MathAbs(pending.htfLevel - pending.h4SweepLow));
   else
      td.sweepSizePips = td.isSell ? ToPips(MathAbs(pending.htfLevel - pending.h4SweepLow))
                         : ToPips(MathAbs(pending.h4SweepHigh - pending.h4SweepLow));

   double candleRange = pending.h4SweepHigh - pending.h4SweepLow;
   double bodySize = MathAbs(pending.h4SweepClose - pending.h4SweepOpen);
   td.sweepBodyPct = (candleRange > 0) ? bodySize / candleRange : 0;

   td.originalLots = 0;
   td.remainingLots = 0;
   td.scaleOutDone = false;
   td.scaleOutTime = 0;
   td.scaleOutPrice = 0;
   td.scaleOutR = 0;
   td.breakevenActivated = false;
   td.timeToBETrigger = MILESTONE_NOT_HIT;
   td.timeToBEStop = MILESTONE_NOT_HIT;
   td.exitR = 0;
   td.maxRReached = 0;

   int beProfileIdx = GetCurrentProfileIndex();
   if(beProfileIdx >= 0)
     {
      td.beTriggerR = gProfiles[beProfileIdx].beTriggerR;
      td.beOffsetR = gProfiles[beProfileIdx].beOffsetR;
     }
   else
     {
      td.beTriggerR = 0.35;
      td.beOffsetR = 0.1;
     }
   td.pairName = _Symbol;

   if(ValidationMode && SimulatedSlippagePips > 0)
     {
      double slippagePrice = SimulatedSlippagePips * (StringFind(_Symbol,"JPY")>=0 ? 0.01 : 0.0001);
      td.fill = td.isSell ? td.entry + slippagePrice : td.entry - slippagePrice;
      td.slippagePips = SimulatedSlippagePips;
      td.best_price = td.fill;
      td.worst_price = td.fill;
     }
   else
     {
      td.fill = td.entry;
      td.slippagePips = 0;
     }

   if(VerboseLogging)
     {
      Print("🎯 TRADE PLAN | ", _Symbol, " ", td.isSell ? "SELL" : "BUY",
            " | Entry: ", DoubleToString(td.entry, _Digits),
            " | Fill: ", DoubleToString(td.fill, _Digits), " (", DoubleToString(td.slippagePips, 1), "p slippage)",
            " | Stop: ", DoubleToString(td.stop, _Digits), " (", DoubleToString(td.stopSizePips, 1), "p)",
            " | Target: ", DoubleToString(td.tp, _Digits), " (", DoubleToString(targetR, 1), "R)",
            " | Level: ", DoubleToString(td.htfLevel, _Digits));
     }
  }

// ===================== FILL RECORDING =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void RecalcTPFromFill(double fillPrice)
  {
   td.fill = fillPrice;
   td.slippagePips = ToPips(MathAbs(fillPrice - td.entry));
   td.fill_time = TimeCurrent();
   td.timeToFill = TimeCurrent();
   td.fillLatencyMs = (int)((td.fill_time - td.entry_time) * 1000);
   td.best_price = fillPrice;
   td.worst_price = fillPrice;

   int retries = 5;
   while(retries > 0 && td.positionID == 0)
     {
      Sleep(100);
      ulong dealTicket = trade.ResultDeal();
      if(dealTicket > 0 && HistoryDealSelect(dealTicket))
        {
         td.positionID = (ulong)HistoryDealGetInteger(dealTicket, DEAL_POSITION_ID);
         break;
        }
      retries--;
     }

   if(PositionSelectByTicket(td.positionID))
     {
      td.originalLots = PositionGetDouble(POSITION_VOLUME);
      td.remainingLots = td.originalLots;
     }
   else
     {
      Print("⚠️ POSITION TRACKING FAILED | Ticket: ", td.positionID, " | Will retry next tick");
     }

   if(td.slippagePips > 0.1)
      Print("⚠️ SLIPPAGE | Planned: ", DoubleToString(td.entry, _Digits),
            " | Filled: ", DoubleToString(fillPrice, _Digits),
            " | Slippage: ", DoubleToString(td.slippagePips, 1), "p");

   LogExecutionQuality();
  }

// ===================== SCALE-OUT =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
void CheckScaleOut()
  {
   if(td.scaleOutDone)
      return;
   if(td.positionID == 0)
      return;
   if(!PositionSelectByTicket(td.positionID))
     {
      state = IDLE;
      return;
     }

   int profileIdx = GetCurrentProfileIndex();
   if(profileIdx < 0)
      return;
   if(!gProfiles[profileIdx].useScaleOut)
      return;
   if(gProfiles[profileIdx].scaleOutLevel <= 0)
      return;

   double currentPrice = PositionGetDouble(POSITION_PRICE_CURRENT);
   double currentR = td.isSell ? (td.fill - currentPrice) / td.risk : (currentPrice - td.fill) / td.risk;

   if(currentR < gProfiles[profileIdx].scaleOutLevel)
      return;

   double lotsToClose = NormalizeDouble(td.originalLots * gProfiles[profileIdx].scaleOutPercent, 2);
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);

   if(lotsToClose < minLot)
      lotsToClose = minLot;
   if(lotsToClose >= td.remainingLots)
      return;

   if(VerboseLogging)
     {
      Print("📊 SCALE_CHECK | ", _Symbol, " | CurrentR: ", DoubleToString(currentR, 2),
            " | Target: ", DoubleToString(gProfiles[profileIdx].scaleOutLevel, 1),
            " | Price: ", DoubleToString(currentPrice, _Digits));
     }

   if(trade.PositionClosePartial(td.positionID, lotsToClose))
     {
      td.scaleOutDone = true;
      td.scaleOutTime = TimeCurrent();
      td.scaleOutPrice = currentPrice;
      td.scaleOutR = currentR;
      td.remainingLots -= lotsToClose;

      Print("📊 SCALE-OUT | ", _Symbol, " | Closed ", DoubleToString(lotsToClose, 2),
            " lots at ", DoubleToString(currentR, 1), "R | Remaining: ", DoubleToString(td.remainingLots, 2));

      int sIdx = GetSessionIndex();
      gSessionPL[sIdx] += td.scaleOutR * 0.25;
     }
  }

// ===================== TRADE ADOPTION & RECOVERY =====================

//+------------------------------------------------------------------+
//|                                                                  |
//+------------------------------------------------------------------+
bool AdoptExistingTrade()
  {
// Check if we already have a tracked trade
   if(td.positionID != 0 && PositionSelectByTicket(td.positionID))
      return true;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
     {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket))
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;

      // Get position details
      bool isSell = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL);
      double openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      double currentSL = PositionGetDouble(POSITION_SL);
      double currentTP = PositionGetDouble(POSITION_TP);
      double lots = PositionGetDouble(POSITION_VOLUME);
      string comment = PositionGetString(POSITION_COMMENT);

      // Parse original risk from comment (stored as "LiqRev_R0.50100" or "LiqCont_R0.50100")
      double risk = 0;
      int pos = StringFind(comment, "_R");
      if(pos >= 0)
        {
         string riskStr = StringSubstr(comment, pos + 2);
         risk = StringToDouble(riskStr);
         if(risk > 0)
            Print("📊 Parsed original risk from comment: ", DoubleToString(risk, 5));
        }

      // If no risk in comment, calculate from current SL (fallback)
      if(risk <= 0)
        {
         risk = MathAbs(openPrice - currentSL);

         // Sanity check: if SL is too tight (already moved to BE), estimate from ATR
         double atr = GetATR(14, PERIOD_H4);
         double minReasonableRisk = atr * 0.8;

         if(risk < minReasonableRisk)
           {
            risk = minReasonableRisk;
            Print("⚠️ SL too tight, estimated risk from ATR: ", DoubleToString(risk, 5));
           }
         else
           {
            Print("📊 Calculated risk from current SL: ", DoubleToString(risk, 5));
           }
        }

      // Validate risk
      if(risk <= 0)
        {
         Print("⚠️ Cannot adopt trade - unable to determine risk");
         continue;
        }

      // Populate TradeData
      td.positionID = ticket;
      td.isSell = isSell;
      td.isReversion = (StringFind(comment, "LiqRev") >= 0);
      td.fill = openPrice;
      td.entry = openPrice;
      td.stop = currentSL;
      td.tp = currentTP;
      td.risk = risk;
      td.originalLots = lots;
      td.remainingLots = lots;
      td.entry_time = (datetime)PositionGetInteger(POSITION_TIME);
      td.fill_time = td.entry_time;
      td.barCount = 0;
      td.scaleOutDone = false;
      td.breakevenActivated = false;

      td.timeToBETrigger = MILESTONE_NOT_HIT;
      td.timeToBEStop = MILESTONE_NOT_HIT;
      td.exitR = 0;

      // Get profile settings
      int profileIdx = GetCurrentProfileIndex();

      if(profileIdx >= 0)
        {
         td.beTriggerR = gProfiles[profileIdx].beTriggerR;
         td.beOffsetR = gProfiles[profileIdx].beOffsetR;
        }
      else
        {
         td.beTriggerR = 0.35;
         td.beOffsetR = 0.1;
        }

      if(profileIdx >= 0)
        {
         td.targetR = gProfiles[profileIdx].optimalTP;

         // Check if partial close already happened (lot size smaller than typical)
         double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
         double typicalLot = minLot * 10; // rough estimate
         if(lots < typicalLot && gProfiles[profileIdx].useScaleOut)
           {
            td.scaleOutDone = true;
            Print("📊 Detected possible partial close (small lot size: ", DoubleToString(lots, 2), ")");
           }
        }
      else
        {
         td.targetR = isSell ? FixedR_TP_Rev : FixedR_TP_Cont;
        }

      // Check if stop is already at breakeven or better
      double beThreshold = risk * 0.05;  // Within 0.05R of entry
      if(isSell)
        {
         if(currentSL < openPrice - beThreshold)
           {
            td.breakevenActivated = true;
            td.timeToBETrigger = td.entry_time;  // Approximate
            Print("🔒 Detected existing BE protection on SELL (SL below entry)");
           }
        }
      else
        {
         if(currentSL > openPrice + beThreshold)
           {
            td.breakevenActivated = true;
            Print("🔒 Detected existing BE protection on BUY (SL above entry)");
           }
        }

      // Reset tracking fields
      td.lastBarTime = iTime(_Symbol, _Period, 0);
      for(int j = 0; j < MILESTONE_COUNT; j++)
         td.timeToR[j] = MILESTONE_NOT_HIT;
      td.timeToSL = MILESTONE_NOT_HIT;
      td.best_price = openPrice;
      td.worst_price = openPrice;

      state = IN_TRADE;

      Print("🔄 ADOPTED EXISTING TRADE | ", _Symbol,
            " | Dir: ", isSell ? "SELL" : "BUY",
            " | Entry: ", DoubleToString(openPrice, _Digits),
            " | Lots: ", DoubleToString(lots, 2),
            " | Risk: ", DoubleToString(risk, 5),
            " | Current SL: ", DoubleToString(currentSL, _Digits),
            " | BE Active: ", td.breakevenActivated ? "YES" : "NO",
            " | Partial Done: ", td.scaleOutDone ? "YES" : "NO");

      return true;
     }
   return false;
  }

