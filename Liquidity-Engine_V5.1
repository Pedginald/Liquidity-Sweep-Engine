              "\tATR_H4_Pips\tATR_M5_Pips\tH4Trend\tVolRegime\tATRPercentile\tADX\tMomentumBefore\tLondonOrNY"
              "\tSlippagePips\tFillLatencyMs\tSession\tYear\tMode\tSimSlippage\tSpreadCost"
              "\tScaleOutDone\tScaleOutR\tScaleOutPrice\tScaleOutTime\tOriginalLots\tRemainingLots"
              "\tBE_TriggerR\tBE_OffsetR\tExitR\tTimeToBETrigger\tTimeToBEStop\tMaxRReached";
      FileWriteString(h,header+"\n");
     }
   else
      FileSeek(h,0,SEEK_END);

   MqlDateTime dt;
   TimeToStruct(td.entry_time,dt);
